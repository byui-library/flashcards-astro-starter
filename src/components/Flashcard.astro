---
export interface Props {
  initialImage: {
    src: string;
    alt: string;
  };
  class?: string;
}

const { initialImage, class: className } = Astro.props;
---

<div id="card" class={`card ${className || ''}`} tabindex="0" aria-live="polite">
  <div id="front-wrapper">
    <img
      id="card-image"
      src={initialImage.src}
      alt={initialImage.alt}
      width="400"
      height="400"
    />
    <video
      id="card-video"
      width="400"
      height="400"
      muted
      loop
      playsinline
      preload="metadata"
      hidden
    ></video>
    <button
      id="video-badge"
      type="button"
      class="video-badge"
      aria-label="Play demonstration video"
      hidden
    >▶</button>
  </div>
  <div id="back" class="back" hidden></div>
</div>