---
import { getImage } from 'astro:assets';
import '../styles.css';

// Import components
import StatsDisplay from '../components/StatsDisplay.astro';
import ControlButtons from '../components/ControlButtons.astro';
import Flashcard from '../components/Flashcard.astro';
import DeckSelector from '../components/DeckSelector.astro';
import ConfigModal from '../components/ConfigModal.astro';

// Import all available decks directly (auto-generated by update-deck-imports.mjs)
import { Foot_Ankle } from '../data/foot-ankle.js';
import { Hip } from '../data/hip.js';
import { Knee } from '../data/knee.js';
import { Shoulder } from '../data/shoulder.js';

// Available decks configuration (auto-generated by update-deck-imports.mjs)
const deckConfigs = [
  { id: 'foot-ankle', module: Foot_Ankle, name: 'Foot/Ankle' },
  { id: 'hip', module: Hip, name: 'Hip' },
  { id: 'knee', module: Knee, name: 'Knee' },
  { id: 'shoulder', module: Shoulder, name: 'Shoulder' }
];

// Build available decks array
const availableDecks = [];
let defaultDeck = null;

for (const config of deckConfigs) {
  if (config.module && Array.isArray(config.module)) {
    const deck = {
      name: config.name,
      id: config.id,
      cards: config.module
    };

    availableDecks.push(deck);

    // Use first deck as default
    if (!defaultDeck) {
      defaultDeck = deck;
    }
  }
}

// Fallback if no decks found
if (availableDecks.length === 0) {
  throw new Error('No valid deck configurations found');
}

// Generate optimized image paths for ALL decks at build time
const optimizedImagePathsByDeck = {};
for (const deck of availableDecks) {
  optimizedImagePathsByDeck[deck.id] = await Promise.all(
    deck.cards.map(async (card) => {
      const optimizedImage = await getImage({
        src: card.image,
        width: 400,
        height: 400,
        format: 'webp'
      });
      return optimizedImage.src;
    })
  );
}

const cards = defaultDeck.cards;
const deckName = defaultDeck.name;

const firstImage = await getImage({
  src: cards[0].image,
  width: 400,
  height: 400,
  format: 'webp'
});
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marvelous Martin's Special Tests Flashcards</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet">
  </head>
  <body class="app">
    <header class="header">
      <h1>Marvelous Martin's Special Tests Flashcards</h1>
      <DeckSelector
        decks={availableDecks.map(deck => ({ id: deck.id, name: deck.name }))}
        defaultDeckId={defaultDeck.id}
      />
    </header>

    <main class="main">
      <Flashcard
        initialImage={{ src: firstImage.src, alt: cards[0].alt }}
      />

      <ControlButtons />

      <StatsDisplay />
    </main>

    <ConfigModal />

    <footer class="footer">
      <span>Offline-ready PWA</span>
    </footer>

    <script src="../scripts/flashcard-app.js"></script>
    <script define:vars={{ cards, deckName, availableDecks, optimizedImagePathsByDeck }}>
      // Initialize the flashcard application
      document.addEventListener('DOMContentLoaded', () => {
        new window.FlashcardApp({
          cards,
          deckName,
          availableDecks,
          optimizedImagePathsByDeck
        });
      });
    </script>
  </body>
</html>
