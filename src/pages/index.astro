---
import { getImage } from 'astro:assets';
import '../styles.css';

// Import components
import StatsDisplay from '../components/StatsDisplay.astro';
import ControlButtons from '../components/ControlButtons.astro';
import Flashcard from '../components/Flashcard.astro';
import DeckSelector from '../components/DeckSelector.astro';
import ConfigModal from '../components/ConfigModal.astro';

// Import all available decks directly (auto-generated by update-deck-imports.mjs)
import { anatomyBones } from '../data/anatomy-bones.js';
import { cardiologyBasics } from '../data/cardiology-basics.js';
import { cardiologyBasics } from '../data/cardiology-basics.js';

// Available decks configuration (auto-generated by update-deck-imports.mjs)
const deckConfigs = [
  { id: 'anatomy-bones', module: anatomyBones, name: 'Anatomy: Bones' }
];

// Build available decks array
const availableDecks = [];
let defaultDeck = null;

for (const config of deckConfigs) {
  if (config.module && Array.isArray(config.module)) {
    const deck = {
      name: config.name,
      id: config.id,
      cards: config.module
    };
    
    availableDecks.push(deck);
    
    // Use first deck as default
    if (!defaultDeck) {
      defaultDeck = deck;
    }
  }
}

// Fallback if no decks found
if (availableDecks.length === 0) {
  throw new Error('No valid deck configurations found');
}

const cards = defaultDeck.cards;
const deckName = defaultDeck.name;

// Generate optimized image paths for all cards at build time
const optimizedImagePaths = await Promise.all(cards.map(async (card) => {
  const optimizedImage = await getImage({
    src: card.image, 
    width: 400, 
    height: 400, 
    format: 'webp'
  });
  return optimizedImage.src;
}));

const firstImage = await getImage({
  src: cards[0].image, 
  width: 400, 
  height: 400, 
  format: 'webp'
});
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>A&P Flashcards</title>
  </head>
  <body class="app">
    <header class="header">
      <h1>A&P Flashcards</h1>
      <DeckSelector 
        decks={availableDecks.map(deck => ({ id: deck.id, name: deck.name }))} 
        defaultDeckId={defaultDeck.id} 
      />
    </header>

    <main class="main">
      <Flashcard 
        initialImage={{ src: firstImage.src, alt: cards[0].alt }} 
      />

      <ControlButtons />

      <StatsDisplay />
    </main>

    <ConfigModal />

    <footer class="footer">
      <span>Offline-ready PWA</span>
    </footer>

    <script src="../scripts/flashcard-app.js"></script>
    <script define:vars={{ cards, deckName, availableDecks, optimizedImagePaths }}>
      // Initialize the flashcard application
      document.addEventListener('DOMContentLoaded', () => {
        new window.FlashcardApp({
          cards,
          deckName,
          availableDecks,
          optimizedImagePaths
        });
      });
    </script>
  </body>
</html>