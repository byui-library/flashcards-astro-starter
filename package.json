{
  "name": "flashcards-astro-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/build-decks.mjs && node scripts/update-deck-imports.mjs && astro build",
    "preview": "astro preview",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "deploy": "npm run build && npm run test:run && git add . && git commit -m \"chore: build and test\" && git push"
  },
  "dependencies": {
    "@vite-pwa/astro": "^1.1.1",
    "astro": "^4.15.0",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.0.8",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.2.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^4.0.8"
  }
}
